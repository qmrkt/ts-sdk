{
  "name": "@question/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for question.market prediction market contracts on Algorand",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./clients/*": {
      "types": "./dist/clients/*.d.ts",
      "default": "./dist/clients/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "algosdk": "^3.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/qmrkt/sdk.git"
  },
  "license": "MIT",
  "author": "Andrei Savin <andrei@andreisavin.com>",
  "homepage": "https://question.market"
}
